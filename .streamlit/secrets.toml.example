# Copy this file to .streamlit/secrets.toml for local development

# Required — https://api.setlist.fm/docs/1.0/index.html
SETLISTFM_API_KEY = "your-setlistfm-key-here"

# Optional — enables "Find Lineup" button
# Register free at https://developer.ticketmaster.com
TICKETMASTER_API_KEY = "your-ticketmaster-key-here"
