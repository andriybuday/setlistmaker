# Copy this file to .streamlit/secrets.toml for local development

# Required — get your free key at https://api.setlist.fm/docs/1.0/index.html
SETLISTFM_API_KEY = "your-setlistfm-key-here"

# Optional — enables automatic lineup lookup from BandsInTown
# Register at https://artists.bandsintown.com/support/public-api
BANDSINTOWN_APP_ID = "your-bandsintown-app-id-here"
